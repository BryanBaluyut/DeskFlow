# =============================================================================
# DeskFlow Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- Application ---
SECRET_KEY=change-me-to-a-random-secret-key
APP_URL=http://localhost:8000

# --- Microsoft Entra ID (Azure AD) ---
ENTRA_CLIENT_ID=your-application-client-id
ENTRA_CLIENT_SECRET=your-client-secret
ENTRA_TENANT_ID=your-tenant-id

# --- Email (Inbound - IMAP) ---
IMAP_HOST=outlook.office365.com
IMAP_PORT=993
IMAP_USER=support@yourdomain.com
IMAP_PASSWORD=your-imap-password
EMAIL_POLL_INTERVAL=60

# --- Email (Outbound - SMTP) ---
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=support@yourdomain.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=support@yourdomain.com
SMTP_FROM_NAME=IT Help Desk

# --- Email Authentication ---
# "basic" for username/password, "oauth2" for Microsoft 365 OAuth2
# OAuth2 uses the Entra ID credentials above (client credentials flow).
# Requires IMAP.AccessAsApp and SMTP.SendAsApp permissions with admin consent.
EMAIL_AUTH_TYPE=basic

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///data/deskflow.db
