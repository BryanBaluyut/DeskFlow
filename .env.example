# =============================================================================
# DeskFlow Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- Application ---
SECRET_KEY=change-me-to-a-random-secret-key
APP_URL=https://localhost
ENVIRONMENT=development
ALLOWED_HOSTS=*

# --- Domain & TLS ---
# Set to your domain for automatic HTTPS via Caddy (e.g., helpdesk.example.com)
# Use "localhost" for local development (self-signed cert)
APP_DOMAIN=localhost

# --- Microsoft Entra ID (Azure AD) ---
ENTRA_CLIENT_ID=your-application-client-id
ENTRA_CLIENT_SECRET=your-client-secret
ENTRA_TENANT_ID=your-tenant-id

# --- Email (Inbound - IMAP) ---
IMAP_HOST=outlook.office365.com
IMAP_PORT=993
IMAP_USER=support@yourdomain.com
IMAP_PASSWORD=your-imap-password
EMAIL_POLL_INTERVAL=60

# --- Email (Outbound - SMTP) ---
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=support@yourdomain.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=support@yourdomain.com
SMTP_FROM_NAME=IT Help Desk

# --- Database ---
# PostgreSQL (recommended for production):
DATABASE_URL=postgresql+asyncpg://deskflow:deskflow@localhost:5432/deskflow
# SQLite (for development/light deployments):
# DATABASE_URL=sqlite+aiosqlite:///data/deskflow.db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=300
POSTGRES_PASSWORD=deskflow

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- Rate Limiting ---
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_API=120/minute
